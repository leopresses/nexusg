# ===============================
# OS / Editor
# ===============================
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ===============================
# Node / Package managers
# ===============================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npmrc
.pnpm-store/

# ===============================
# Build outputs
# ===============================
dist/
build/
out/
coverage/
*.tsbuildinfo

# ===============================
# Vite / tooling caches
# ===============================
.vite/
.cache/
.eslintcache
.turbo/
.parcel-cache/
.next/
.nuxt/

# ===============================
# Logs
# ===============================
logs/
*.log

# ===============================
# Env files (SENSITIVE)
# ===============================
.env
.env.*
!.env.example

# If you use dotenv local overrides
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===============================
# Supabase (local / generated)
# ===============================
# Supabase CLI local settings (often contains local DB config)
.supabase/
# Generated types can be committed if you want; if not, ignore:
# src/integrations/supabase/types.ts
# src/integrations/supabase/database.types.ts

# ===============================
# Secrets / Keys / Certificates
# ===============================
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
secrets/
secret/
keys/
certs/

# Service account / cloud keys (common names)
*service-account*.json
firebase*.json
google*.json
gcp*.json
aws*.json

# ===============================
# Local DB / dumps / backups
# ===============================
*.sqlite
*.sqlite3
*.db
*.dump
*.bak
*.backup
*.sql.gz
*.tgz

# ===============================
# Uploads / local storage exports
# ===============================
uploads/
tmp/
temp/

# ===============================
# Optional: lockfiles (choose ONE strategy)
# Keep lockfile for reproducible builds (recommended)
# (Leave these UNignored by default)
# ===============================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
